{
  "name": "@trading-platform/persistence",
  "version": "1.0.0",
  "packageManager": "pnpm@10.32.1",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "pnpm run build && pnpm exec concurrently --kill-others --names tsc,worker,cron \"pnpm run dev:build\" \"pnpm run dev:worker\" \"pnpm run dev:cron\"",
    "dev:build": "tsc -w --preserveWatchOutput",
    "dev:worker": "node --watch dist/index.js",
    "dev:cron": "node --watch dist/cron.js",
    "db:seed": "node dist/seed-db.js",
    "refresh:views": "node dist/cron.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@trading-platform/config": "workspace:*",
    "@trading-platform/logger": "workspace:*",
    "@trading-platform/shared-types": "workspace:*",
    "dotenv": "^17.2.3",
    "pg": "^8.12.0",
    "redis": "^4.6.14"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "@types/pg": "^8.11.6",
    "typescript": "^5.6.3"
  }
}
